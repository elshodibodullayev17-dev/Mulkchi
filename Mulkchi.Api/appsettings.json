{
  "ConnectionStrings": {
    "DefaultConnection": "${MULKCHI_DB_CONNECTION_STRING:-Server=(localdb)\\\\mssqllocaldb;Database=MulkchiDb;Trusted_Connection=True;MultipleActiveResultSets=true}"
  },
  "JwtSettings": {
    "Secret": "${MULKCHI_JWT_SECRET:-CHANGE_ME_USE_ENVIRONMENT_VARIABLE_OR_USER_SECRETS}",
    "Issuer": "Mulkchi",
    "Audience": "MulkchiUsers",
    "ExpiryDays": 7
  },
  "EmailSettings": {
    "SmtpHost": "${MULKCHI_SMTP_HOST:-smtp.gmail.com}",
    "SmtpPort": "${MULKCHI_SMTP_PORT:-587}",
    "SenderEmail": "${MULKCHI_SENDER_EMAIL:-}",
    "SenderPassword": "${MULKCHI_SENDER_PASSWORD:-}",
    "SenderName": "Mulkchi"
  },
  "AllowedOrigins": [
    "https://mulkchi.uz",
    "https://www.mulkchi.uz"
  ],
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
